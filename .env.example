# Authentication — set to enable password protection
# PI_AUTH_PASSWORD=your-secret-password

# Coding harness: 'pi' (default) or 'claude-code'
# PI_HARNESS=pi

# Pi binary path (default: 'pi' from PATH)
# PI_BIN=pi

# Claude Code binary path (default: 'claude' from PATH)
# CLAUDE_BIN=claude

# Session storage directory (default: ~/.pi/agent/sessions)
# PI_SESSIONS_DIR=~/.pi/agent/sessions

# Worktree directory for job isolation (default: .worktrees/ relative to project)
# PI_WORKTREE_DIR=.worktrees

# Host/origin for callbacks (default: auto-detected)
# PI_REMOTE_HOST=http://localhost:4020

# --- Job Skills ---
# Skill names to invoke for each job phase. If unset, hardcoded prompts are used.

# Fire-and-forget tasks (max_loops=0) — runs once with self-review
# PI_JOB_TASK_SKILL=issue-worker

# Task/fix phase inside a review loop (max_loops>0)
# PI_JOB_LOOP_TASK_SKILL=issue-worker

# --- PR Pre-Analysis ---
# OpenRouter API key — when set, uses OpenRouter for structured PR classification
# instead of the harness CLI. Falls back to harness CLI if unset or on failure.
# OPEN_ROUTER_API_KEY=sk-or-...

# OpenRouter classifier model (default: mistralai/mistral-small-2603)
# PI_CLASSIFIER_MODEL=mistralai/mistral-small-2603

# Harness CLI fallback model (default: haiku for claude-code, gemini-2.0-flash for pi)
# PI_ANALYSIS_MODEL=haiku

# --- GitHub PR Poller ---
# Polling interval in seconds (default: 600 = 10 minutes)
# PI_PR_POLL_INTERVAL_SECONDS=600

# Max concurrent running jobs (default: 5)
# PI_PR_POLL_CONCURRENCY=5

# Max age of PRs (in days) to consider when a monitored repo has assigned_only
# disabled. PRs created before this cutoff are skipped. Ignored when
# assigned_only is on. (default: 30)
# PI_PR_MAX_AGE_DAYS=30

# Allow additional server hosts
# __VITE_ADDITIONAL_SERVER_ALLOWED_HOSTS
